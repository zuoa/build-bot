{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "target": "ES2022",
    "lib": ["ES2022"],
    "strict": true,
    "types": ["node"]
  },
  "include": ["vite.config.ts", "src/main", "src/shared"]
}
